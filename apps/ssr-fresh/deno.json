{
  "tasks": {
    "dev": "deno run -A --watch=static/,routes/ dev.ts",
    "build": "deno run -A npm:vite build",
    "start": "deno serve --port 3000 -A _fresh/server/server-entry.mjs",
    "preview": "deno serve --port 3000 -A _fresh/server/server-entry.mjs"
  },
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@2.3.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@1.0.4",
    "preact": "npm:preact@10.29.1",
    "preact/": "npm:preact@10.29.1/",
    "preact/jsx-runtime": "npm:preact@10.29.1/jsx-runtime",
    "preact/jsx-dev-runtime": "npm:preact@10.29.1/jsx-dev-runtime",
    "@preact/signals": "npm:@preact/signals@2.9.0",
    "vite": "npm:vite@7.3.2"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}
