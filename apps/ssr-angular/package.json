{
  "name": "ssr-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "serve:ssr:ssr-angular": "node dist/ssr-angular/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "21.2.10",
    "@angular/compiler": "21.2.10",
    "@angular/core": "21.2.10",
    "@angular/forms": "21.2.10",
    "@angular/platform-browser": "21.2.10",
    "@angular/platform-server": "21.2.10",
    "@angular/router": "21.2.10",
    "@angular/ssr": "21.2.8",
    "express": "5.2.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.8",
    "@angular/cli": "21.2.8",
    "@angular/compiler-cli": "21.2.10",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "typescript": "5.9.3"
  }
}