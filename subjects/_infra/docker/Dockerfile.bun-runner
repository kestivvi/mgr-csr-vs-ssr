# Standard Bun Runtime (Runner) for MGR Research
FROM oven/bun:1.3.13-slim

WORKDIR /app

# Standard Production Environment
ENV NODE_ENV=production \
    PORT=3000 \
    HOSTNAME=0.0.0.0 \
    BUN_JSC_forceRAMSize=1610612736 \
    BUN_GARBAGE_COLLECTOR_LEVEL=1 \
    BUN_METRICS_SINK=0

# Use the official Bun non-root user
USER bun

# Standardize ports
EXPOSE 3000
